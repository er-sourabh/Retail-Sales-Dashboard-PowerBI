model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation __PBI_TimeIntelligenceEnabled = 0

annotation PBI_QueryOrder = ["Address","Customers","DateTable","Products","Regions","Returns","SalesData","Segment","ShipMode","StartDate","All Measure"]

annotation PBI_ProTooling = ["DevMode"]

ref table Address
ref table Customers
ref table DateTable
ref table Products
ref table Regions
ref table Returns
ref table SalesData
ref table Segment
ref table ShipMode
ref table 'All Measure'
ref table Parameter

ref cultureInfo en-US


	column FY-YEAR =
			IF(DateTable[Month] <= 3,
			            "FY"&YEAR(DateTable[Date])-1&"-"&YEAR(DateTable[Date]),
			            "FY"&YEAR(DateTable[Date])&"-"&YEAR(DateTable[Date])+1
			            )
		lineageTag: 227d5f3c-4ee7-441a-9c23-2e55b9324718
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column FY-QTR = SWITCH(TRUE(),MONTH(DateTable[Date])<=3,"Qtr 4",MONTH(DateTable[Date])<=6,"Qtr 1",MONTH(DateTable[Date])<=9,"Qtr 2","Qtr 3")
		lineageTag: 9c883210-adfa-4b05-83f0-990dd9e66e60
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

